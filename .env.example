# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Capacitor owner shell loads this URL (defaults to NEXT_PUBLIC_APP_URL)
# CAPACITOR_SERVER_URL="https://stallside.app"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/stallside?schema=public"

# Email (optional locally — magic links + sale/low-stock alerts log to console)
# RESEND_API_KEY=""
# EMAIL_FROM="Stallside <noreply@stallside.app>"

# Push (optional — without this, push payloads log to the server console)
# FCM_SERVER_KEY="AAAA..."

# Stripe (Connect + Checkout — Apple Pay / Google Pay via Checkout)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
