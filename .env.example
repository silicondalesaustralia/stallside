# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Capacitor owner shell loads this URL (defaults to NEXT_PUBLIC_APP_URL)
# CAPACITOR_SERVER_URL="https://stallside.app"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Database
# Runtime: Neon pooled URL is fine for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/stallside?schema=public&sslmode=verify-full"
# Migrations: set this to Neon’s *direct* (non-pooler) connection string in Vercel.
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-....neon.tech/neondb?sslmode=require"

# Email (optional locally — magic links + sale/low-stock alerts log to console)
# RESEND_API_KEY=""
# EMAIL_FROM="Stallside <hello@stallside.app>"
# Where contact-form submissions are delivered (public mailto stays hello@stallside.app)
# CONTACT_EMAIL="jono@silicondales.com"

# iOS push via APNs (Capacitor on iPhone — no Firebase required)
# APNS_KEY_ID=""
# APNS_TEAM_ID=""
# APNS_BUNDLE_ID="com.myfarmstand.owner"
# APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_USE_SANDBOX="true"

# Android push (optional — FCM)
# FCM_SERVER_KEY="AAAA..."

# Browser / PWA web push (owner phone alerts — home screen install)
# Generate: npx web-push generate-vapid-keys --json
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""

# Stripe — one platform account, two uses:
# 1) Billing: owners pay Stallside (SaaS subscription) — Price IDs per currency
# 2) Connect: owners receive stand customer payments (Express + Checkout)
STRIPE_SECRET_KEY="sk_test_..."
# Optional: keep live platform key above, and use test keys only for /demo Card checkout
# STRIPE_SECRET_KEY_TEST="sk_test_..."
# Test-mode Connect account id for demo Card (acct_…) — required when STRIPE_SECRET_KEY is sk_live_
# DEMO_STRIPE_ACCOUNT_ID="acct_..."
# Public demo stands (two stands under admin owner — USA also serves Rest of world)
# Names: "Green Valley Eggs Australia" / "Green Valley Eggs USA"
# DEMO_STAND_SLUG_AU="green-valley-eggs-australia"
# DEMO_STAND_SLUG_US="green-valley-eggs-usa"
# Your account destination (SaaS billing subscriptions / invoices)
STRIPE_WEBHOOK_SECRET="whsec_..."
# Connected accounts destination (Tap & Go Checkout + account.updated) — same URL
# STRIPE_WEBHOOK_SECRET_CONNECT="whsec_..."
# Optional test-mode webhook secrets (same URL) for demo Card fulfillment
# STRIPE_WEBHOOK_SECRET_TEST="whsec_..."
# STRIPE_WEBHOOK_SECRET_TEST_CONNECT="whsec_..."
# Recurring cash-plan Prices (one Product, four Prices). List: AUD 6.99 / USD 4.99 / GBP 3.99 / EUR 4.99
STRIPE_PRICE_ID_CASH_AUD="price_..."
STRIPE_PRICE_ID_CASH_USD="price_..."
STRIPE_PRICE_ID_CASH_GBP="price_..."
STRIPE_PRICE_ID_CASH_EUR="price_..."
# Legacy alias for AUD (optional if STRIPE_PRICE_ID_CASH_AUD is set)
# STRIPE_PRICE_ID_CASH="price_..."
# Recurring Card / Tap & Go Prices (no free trial). List: AUD 19.99 / USD 14.99 / GBP 11.99 / EUR 14.99
# STRIPE_PRICE_ID_CARD_AUD="price_..."
# STRIPE_PRICE_ID_CARD_USD="price_..."
# STRIPE_PRICE_ID_CARD_GBP="price_..."
# STRIPE_PRICE_ID_CARD_EUR="price_..."
# Also enable Customer Portal in Stripe Dashboard → Settings → Billing → Customer portal
# Webhook events (platform + Connect): checkout.session.completed,
#   checkout.session.async_payment_succeeded, checkout.session.async_payment_failed,
#   checkout.session.expired, account.updated,
#   customer.subscription.updated, customer.subscription.deleted, invoice.paid
# Apple Pay: enable in Stripe Dashboard → Payment methods; verify stallside.app
#   (test + live). Google Pay: confirm enabled. Wallets appear on Checkout automatically.
# Cron (Vercel daily trial-ended emails → /api/cron/trial-reminders)
# CRON_SECRET="generate-a-long-random-string"
# PayPal multiparty (Partner Referrals) — needs PayPal partner approval
# Client ID is also passed to the browser for the official PayPal Buttons SDK
# Sandbox: PAYPAL_MODE=sandbox + sandbox Client ID/Secret + sandbox partner merchant id
# Live:    PAYPAL_MODE=live   + live Client ID/Secret + live partner merchant id
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""
# PAYPAL_PARTNER_MERCHANT_ID=""
# PAYPAL_BN_CODE=""
# PAYPAL_MODE="sandbox"
# Set to 1 when Partner Referrals is approved and Connect is ready in production:
# PAYPAL_CONNECT_ENABLED="1"
# Until Partner Referrals is approved (403 NOT_AUTHORIZED), use direct mode:
# PAYPAL_CONNECT_MODE="direct"
# Optional override of merchant id for direct checkout (defaults to PARTNER_MERCHANT_ID):
# PAYPAL_DIRECT_MERCHANT_ID=""
# Live webhook: https://stallside.app/api/paypal/webhook
# Events: PAYMENT.CAPTURE.COMPLETED, CHECKOUT.ORDER.APPROVED, CHECKOUT.ORDER.COMPLETED
# PAYPAL_WEBHOOK_ID=""
# After switching sandbox → live: owners must Connect PayPal again (live Business account).
