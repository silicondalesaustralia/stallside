# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Capacitor owner shell loads this URL (defaults to NEXT_PUBLIC_APP_URL)
# CAPACITOR_SERVER_URL="https://stallside.app"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Database
# Runtime: Neon pooled URL is fine for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/stallside?schema=public&sslmode=verify-full"
# Migrations: set this to Neon’s *direct* (non-pooler) connection string in Vercel.
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-....neon.tech/neondb?sslmode=require"

# Email (optional locally — magic links + sale/low-stock alerts log to console)
# RESEND_API_KEY=""
# EMAIL_FROM="Stallside <hello@stallside.app>"

# iOS push via APNs (Capacitor on iPhone — no Firebase required)
# APNS_KEY_ID=""
# APNS_TEAM_ID=""
# APNS_BUNDLE_ID="com.myfarmstand.owner"
# APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_USE_SANDBOX="true"

# Android push (optional — FCM)
# FCM_SERVER_KEY="AAAA..."

# Stripe — one platform account, two uses:
# 1) Billing: owners pay Stallside (SaaS subscription) — needs STRIPE_PRICE_ID_CASH
# 2) Connect: owners receive stand customer payments (Express + Checkout)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Create a recurring Price in Stripe Dashboard for the cash plan ($6.99 AUD / mo)
STRIPE_PRICE_ID_CASH="price_..."
# Also enable Customer Portal in Stripe Dashboard → Settings → Billing → Customer portal
# Webhook events: checkout.session.completed, checkout.session.expired,
#   customer.subscription.updated, customer.subscription.deleted, invoice.paid
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# PayPal (Partner Connect + Checkout — requires PayPal Complete Payments partner account)
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""
# PAYPAL_PARTNER_MERCHANT_ID=""
# PAYPAL_BN_CODE=""
# PAYPAL_MODE="sandbox"
